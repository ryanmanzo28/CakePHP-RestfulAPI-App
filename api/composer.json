{
  "name": "hydracor/api",
  "description": "Hydracor CakePHP REST API glue for middleware",
  "require": {
    "php": "^8.0",
    "firebase/php-jwt": "^6.0",
    "psr/http-message": "^1.0",
    "psr/http-server-handler": "^1.0",
    "cakephp/cakephp": "^5.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "config": {
    "policy": {
      "advisories": {
        "block": false
      }
    }
  }
}
